---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import BookingLink from '~/components/widgets/BookingLink.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Contact commercial et accompagnement',
};

const contactEmail = SITE?.contactEmail ?? '';
const bookingUrl = SITE?.bookingUrl ?? '';
---

<Layout metadata={metadata}>
  <!-- Widget HeroText ******************* -->

  <HeroText tagline="Contact" title="Parlons de votre contexte" />

  <BookingLink
    id="booking"
    title="Réservez un échange avec notre équipe"
    subtitle="Choisissez un créneau pour cadrer vos enjeux, vos objectifs et vos contraintes."
    bookingUrl={bookingUrl}
    description="Nous pouvons intervenir sur un audit, une trajectoire plateforme, un besoin de formation ou une demande plus ponctuelle."
  />

  <!-- Widget Features2 ************** -->

  <Features2
    title="Comment nous joindre"
    items={[
      {
        title: 'Demande générale',
        description: `Contactez-nous pour toute question sur votre compte, la facturation, l'accès aux services ou une demande d'information plus large.`,
      },
      {
        title: 'Trajectoire plateforme',
        description:
          'Échangez avec nous pour choisir la bonne offre, comprendre la trajectoire possible et planifier un cadrage adapté.',
      },
      {
        title: 'Question technique',
        description:
          "Parlez-nous d'un sujet d'intégration, d'installation ou d'un blocage technique lié à votre plateforme.",
      },
      {
        title: 'Prise de rendez-vous',
        description: 'Réservez directement un créneau via notre agenda partagé ci-dessus.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Email',
        description: contactEmail,
        icon: 'tabler:mail',
      },
      {
        title: 'Présence',
        description: 'Marseille, Aix-en-Provence, France',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
