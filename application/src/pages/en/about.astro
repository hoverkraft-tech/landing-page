---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import { getLangFromUrl, useTranslatedPath } from '~/i18n/utils';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Hoverkraft',
  description:
    'Learn about the vision, values, and team behind the Hoverkraft method and its connector-driven approach.',
};

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Our DNA"
    image={{
      src: '~/assets/images/pages/about/about-us.png',
      alt: 'Developer liberation with Hoverkraft',
    }}
  >
    <Fragment slot="title">Platform Engineers committed to team autonomy</Fragment>

    <Fragment slot="subtitle">
      Hoverkraft was born from a simple observation: without solid integration layers, the best tools do not deliver
      their full value. We combine method, open-source building blocks, and senior guidance to help organizations build
      a more reliable and reversible delivery model.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="What we measure"
    subtitle="Our commitments are verified through DORA, SPACE, and Lean on every mission."
    stats={[
      { title: 'Time-to-market gains', amount: '40-60%' },
      { title: 'Incidents reduced', amount: '60-80%' },
      { title: 'Team satisfaction', amount: '+40-60%' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Why we exist"
    subtitle="A field-tested conviction: the platform must be an accelerator, not a cost center."
    columns={3}
    isBeforeContent
    items={[
      {
        title: 'Vision',
        description: 'Free developers so they can deliver business value without operational friction.',
        icon: 'tabler:target',
      },
      {
        title: 'Connector-first approach',
        description:
          'We orchestrate your existing tools through open-source glue to avoid lock-in and ensure reversibility.',
        icon: 'tabler:puzzle',
      },
      {
        title: 'Continuous measurement',
        description: 'DORA, SPACE, and Lean guide priorities with evidence shared with your teams.',
        icon: 'tabler:report-analytics',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    id="manifesto"
    columns={3}
    isAfterContent
    items={[
      {
        title: 'Hoverkraft Manifesto',
        description: 'A published framework that aligns stakeholders on the target platform state.',
        icon: 'tabler:book',
      },
      {
        title: 'Training & certification',
        description: "Structured learning paths to strengthen your teams' Platform Engineering maturity over time.",
        icon: 'tabler:sparkles',
      },
      {
        title: 'Kraft Builders',
        description: 'A senior task force that co-builds, transfers, and secures critical initiatives.',
        icon: 'tabler:users',
      },
      {
        title: 'OpenKraft',
        description: 'Maintained open-source connectors, DORA dashboards, and an active community.',
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Total transparency',
        description: 'Open code, complete documentation, regular reporting, and shared governance.',
        icon: 'tabler:eye',
      },
      {
        title: 'Sovereignty by design',
        description: 'An approach built for reversibility, control, and alignment with sovereignty requirements.',
        icon: 'tabler:shield-star',
      },
    ]}
    image={{
      src: '~/assets/images/pages/about/hoverkraft-platform-pillars.png',
      alt: 'OpenKraft community illustration',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    id="values"
    title="Our values"
    subtitle="They guide every decision, from product roadmap to interactions with your teams."
    items={[
      {
        title: 'Radical honesty',
        description: 'We say what truly blocks your teams, with evidence, even when it challenges the status quo.',
      },
      {
        title: 'Skill transfer',
        description: 'The mission succeeds only when your teams can continue without us, equipped and trained.',
      },
      {
        title: 'Measured impact',
        description: 'No slideware: every deliverable comes with DORA/SPACE indicators and field feedback.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="What sets us apart"
    subtitle="A structured method, an engineer's posture, and a constant requirement for evidence."
    isReversed
    items={[
      {
        title: 'Hoverkraft Method',
        description: 'A complete operating framework, from audit to day-to-day execution, documented and shareable.',
        icon: 'tabler:manual-gearbox',
      },
      {
        title: 'Open-source building blocks',
        description: 'We publish connectors to avoid black boxes and make contribution easier.',
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Kraft Builders',
        description: 'A senior team blending consulting and delivery to operate in complex contexts.',
        icon: 'tabler:users',
      },
    ]}
  />

  <Content
    id="team"
    isReversed
    title="A hybrid team"
    subtitle="Platform engineers, product leaders, and Lean coaches who have lived the pain of delivery."
    items={[
      {
        title: 'Platform engineers',
        description: 'Experts in Kubernetes, GitOps, observability, security, and laptop-to-prod automation.',
      },
      {
        title: 'Transformation coaches',
        description: 'Lean/DORA/SPACE specialists to guide cultural and organisational change.',
      },
      {
        title: 'Product & Ops',
        description: 'Roadmap steering, business alignment, and OpenKraft community animation.',
      },
    ]}
    image={{
      src: '~/assets/images/pages/about/team.png',
      alt: 'Hoverkraft team driving the platform',
    }}
  />

  <CallToAction
    actions={[
      { text: 'Read testimonials', href: '/en/testimonials' },
      { variant: 'primary', text: 'Talk to a Kraft Builder', href: translatePath('/contact') },
      { text: 'Explore the method', href: translatePath('/methodology') },
    ]}
  >
    <Fragment slot="title">Ready to build delivery on stronger foundations?</Fragment>
    <Fragment slot="subtitle">
      Let's explore how the Hoverkraft method can strengthen your delivery model over time.
    </Fragment>
  </CallToAction>
</Layout>
