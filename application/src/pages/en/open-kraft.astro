---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'OpenKraft - Resources',
  description:
    'Explore HoverKraft open-source connectors, documentation, and community resources to accelerate your platform.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="OpenKraft"
    actions={[
      {
        text: 'Access GitHub',
        href: 'https://github.com/hoverkraft-tech',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      { text: 'View documentation', href: 'https://docs.hoverkraft.cloud', target: '_blank', variant: 'primary' },
      {
        text: 'Access GitLab',
        href: 'https://gitlab.com/hoverkraft-tech/',
        target: '_blank',
        icon: 'tabler:brand-gitlab',
      },
    ]}
    image={{
      src: '~/assets/images/pages/shared/open-source.webp',
      alt: 'OpenKraft community',
    }}
  >
    <Fragment slot="title">The open-source ecosystem for your internal platform</Fragment>

    <Fragment slot="subtitle">
      OpenKraft brings together reusable connectors, templates, dashboards, and field-tested guidance. It is designed
      for developers, platform teams, and leaders who want to accelerate without losing control.
    </Fragment>
  </Hero>

  <Note
    title="Philosophy"
    description="Knowledge that does not circulate gets lost. We publish the building blocks needed to apply the HoverKraft method in real-world environments."
  />

  <Content
    isReversed
    title="What you will find in OpenKraft"
    items={[
      {
        title: 'CI/CD connectors',
        description: 'Ready-to-use pipelines for GitHub Actions, GitLab CI, and ArgoCD, including promotion patterns.',
      },
      {
        title: 'Integrated observability',
        description: 'Grafana dashboards, Prometheus alerting, and OpenTelemetry traces already wired together.',
      },
      {
        title: 'Security by design',
        description: 'IAM playbooks, secrets management, and compliance patterns shaped by concrete constraints.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80',
      alt: 'HoverKraft open source resources',
    }}
  />

  <Features2
    title="Why contribute?"
    subtitle="A maintained ecosystem shaped by feedback from the field."
    columns={2}
    items={[
      {
        title: 'Field-tested feedback',
        description: 'Each contribution is tied to a real-world use case and documented with implementation context.',
        icon: 'tabler:users',
      },
      {
        title: 'HoverKraft review',
        description: 'Our team reviews, tests, and validates every new connector before publication.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Community support',
        description: 'Access our community space to exchange practices, questions, and lessons learned.',
        icon: 'tabler:messages',
      },
      {
        title: 'Collaborative roadmap',
        description: 'Help prioritize the next connectors and patterns that would deliver the most value.',
        icon: 'tabler:road',
      },
    ]}
  />

  <Steps
    title="How to contribute"
    items={[
      {
        title: '1. Fork the repository',
        description: 'Choose the connector you want to improve or create a new one from our templates.',
        icon: 'tabler:git-branch',
      },
      {
        title: '2. Follow the guide',
        description: 'Each repository includes contribution guidance and automated tests that are ready to run.',
        icon: 'tabler:book',
      },
      {
        title: '3. Open a pull request',
        description: 'Submit your connector and our team will help you get it ready for publication.',
        icon: 'tabler:git-pull-request',
      },
      {
        title: '4. Share the rollout',
        description: 'Present your implementation to the community and document the outcomes you observed.',
        icon: 'tabler:microphone',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1600&q=80',
      alt: 'Community collaboration',
    }}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Explore GitHub',
        href: 'https://github.com/hoverkraft-tech',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: 'View documentation',
        href: 'https://docs.hoverkraft.cloud',
        target: '_blank',
      },
      {
        variant: 'primary',
        text: 'Explore GitLab',
        href: 'https://gitlab.com/hoverkraft-tech',
        target: '_blank',
        icon: 'tabler:brand-gitlab',
      },
    ]}
  >
    <Fragment slot="title">Ready to contribute to OpenKraft?</Fragment>

    <Fragment slot="subtitle">
      Share your connectors, document your lessons learned, and help other teams accelerate without starting from
      scratch.
    </Fragment>
  </CallToAction>
</Layout>
