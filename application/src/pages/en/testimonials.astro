---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import { getLangFromUrl, useTranslatedPath } from '~/i18n/utils';
import Layout from '~/layouts/PageLayout.astro';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const metadata = {
  title: 'HoverKraft testimonials',
  description:
    'Read anonymized field feedback from teams that improved platform and delivery operations with the HoverKraft method.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Testimonials"
    actions={[
      { variant: 'primary', text: 'Talk to a Kraft Builder', href: `${translatePath('/contact')}#booking` },
      { text: 'Explore the method', href: translatePath('/methodology') },
    ]}
    image={{
      src: '~/assets/images/pages/about/team.png',
      alt: 'HoverKraft team',
    }}
  >
    <Fragment slot="title">Field feedback from real delivery transformations</Fragment>

    <Fragment slot="subtitle">
      These anonymized excerpts summarize what teams most often describe after a HoverKraft engagement: clearer
      priorities, better visibility into flow, and lower operational cognitive load.
    </Fragment>
  </Hero>

  <Testimonials
    tagline="Anonymized feedback"
    title="What teams tend to highlight"
    subtitle="Reworked mission excerpts that preserve confidentiality while keeping the useful lessons visible."
    testimonials={[
      {
        title: 'Creating a shared direction',
        testimonial:
          'The DORA/SPACE frame gave sponsors and the platform team the same language. We moved from vague ambition to a roadmap with clear trade-offs in a few weeks.',
        name: 'Anonymous feedback',
        job: 'Engineering leadership - industrial mid-market company',
      },
      {
        title: 'Lowering cognitive load',
        testimonial:
          'Templates and playbooks removed a lot of repetitive glue work. Teams got back time to deliver instead of rebuilding the same operational scaffolding.',
        name: 'Anonymous feedback',
        job: 'Platform lead - B2B SaaS company',
      },
      {
        title: 'Making proof visible',
        testimonial:
          'The biggest step forward was the visibility created by the dashboards and recurring reviews. Investment, incidents, and autonomy finally became evidence-based discussions.',
        name: 'Anonymous feedback',
        job: 'CTO - multi-site organization',
      },
    ]}
  />

  <Features2
    title="Why these testimonials matter"
    subtitle="They give a useful signal without turning the site into a wall of client logos."
    columns={2}
    items={[
      {
        title: 'Readable impact',
        description: 'They emphasize visibility, trade-offs, and lasting operating changes rather than vague claims.',
        icon: 'tabler:eye-check',
      },
      {
        title: 'Confidential by design',
        description: 'The missions remain confidential while the useful patterns and outcomes can still be shared.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Concrete operating effects',
        description: 'Teams talk about flow, rituals, templates, and transfer instead of generic satisfaction slogans.',
        icon: 'tabler:tool',
      },
      {
        title: 'Better qualification',
        description: 'They help visitors decide whether their own context resembles the situations already supported.',
        icon: 'tabler:map-search',
      },
    ]}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Discuss your context', href: `${translatePath('/contact')}#booking` },
      { text: 'View offers', href: translatePath('/offers') },
    ]}
  >
    <Fragment slot="title">Want to see whether your context matches these outcomes?</Fragment>
    <Fragment slot="subtitle"
      >Share your current delivery challenges and we will help you identify the most relevant level of support.</Fragment
    >
  </CallToAction>
</Layout>