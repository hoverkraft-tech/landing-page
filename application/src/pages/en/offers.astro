---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Pricing from '~/components/widgets/pricing/Pricing.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { Icon } from 'astro-icon/components';

import { getLangFromUrl, useTranslatedPath } from '~/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const metadata = {
  title: 'HoverKraft offers',
  description:
    'Choose the Hoverkraft offer that fits your platform maturity: audit, autonomy, restart, or Platform Engineer as a Service.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Our offers"
    actions={[
      { variant: 'primary', text: 'Talk to a Kraft Builder', href: `${translatePath('/contact')}#booking` },
      { text: 'Explore the methodology', href: translatePath('/methodology') },
    ]}
    image={{
      src: '~/assets/images/pages/offers/programming-1.webp',
      alt: 'Overview of HoverKraft offers',
    }}
  >
    <Fragment slot="title">Offers designed to structure delivery, step by step</Fragment>

    <Fragment slot="subtitle">
      From a focused audit to managed execution (PEaaS), every HoverKraft offer combines method, open-source connectors,
      and senior guidance. Choose the option that fits your maturity level and business priorities.
      <span class="block mt-2 text-sm">
        Not sure where to start? Take the{' '}
        <a href={translatePath('/maturity-assessment')} class="font-semibold text-primary underline underline-offset-4">
          maturity radar
        </a>
        first (5 min).
      </span>
    </Fragment>
  </Hero>

  <Pricing
    title="Our packs"
    subtitle="Clear commitments, concrete deliverables, measurable outcomes."
    prices={[
      {
        title: 'Hoverkraft Audit',
        subtitle: 'A two-day mapping exercise to make your friction points explicit',
        price: '2 500',
        currency: '€',
        period: 'excl. VAT (2 days, indicative)',
        items: [
          { description: 'Interviews with dev/ops/product teams and review of your assets' },
          { description: 'Map of existing connectors and friction points' },
          { description: 'Initial DORA/SPACE score + prioritized recommendations' },
        ],
        callToAction: { text: 'Schedule the audit', href: '/contact#booking' },
      },
      {
        title: 'Autonomy Package',
        subtitle: 'Workshop, toolkit, and follow-up to anchor the HoverKraft method',
        price: '1 800',
        currency: '€',
        period: 'excl. VAT (5h format, indicative)',
        items: [
          { description: 'Structuring workshop + Hoverkraft tooling kit' },
          { description: '6-month roadmap and DORA/SPACE milestones' },
          { description: 'Follow-up session to secure execution' },
        ],
        callToAction: { text: 'Build the plan', href: '/contact' },
        hasRibbon: true,
        ribbonTitle: 'Popular',
      },
      {
        title: 'Restart (Full transformation)',
        subtitle: 'Audit, a 6-month roadmap, then 6 to 12 months of support',
        price: '25 000',
        currency: '€',
        period: 'excl. VAT + follow-up (indicative, adjusted to context)',
        items: [
          { description: 'Transformation program with shared governance' },
          { description: 'Full deployment of Hoverkraft glue (CI/CD, observability, IAM)' },
          { description: 'Certified training and DORA/SPACE rituals' },
        ],
        callToAction: { text: 'Launch the restart', href: '/contact' },
      },
      {
        title: 'Platform Engineer as a Service',
        subtitle: 'Continuous resources to operate your platform',
        price: '3 000',
        currency: '€',
        period: 'excl. VAT / month (indicative)',
        items: [
          { description: 'Dedicated resources and joint prioritization' },
          { description: 'Continuous roadmap, shared run, and executive reporting' },
          { description: 'Access to the OpenKraft community and connectors' },
        ],
        callToAction: { text: 'Discuss PEaaS', href: '/contact' },
      },
    ]}
  />

  <aside class="mx-auto mt-6 max-w-4xl px-4 sm:px-6" aria-label="Pricing information">
    <div
      class="flex items-center gap-3 rounded-lg border border-primary/20 bg-primary/5 px-4 py-3 text-base shadow-sm dark:border-primary/30"
    >
      <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
        <Icon name="tabler:info-circle" class="h-5 w-5" />
      </div>
      <p class="text-default font-medium leading-snug">
        Audit fees are deducted if a <span class="font-semibold text-default">Restart</span> contract is signed as the next
        step.
      </p>
    </div>
  </aside>

  <Content
    isReversed
    title="What every pack guarantees"
    items={[
      {
        title: 'Tangible deliverables',
        description: 'Written report, prioritized backlog, DORA/SPACE dashboards and deployed glue source code.',
      },
      {
        title: 'Skill transfer',
        description: 'Training and pairing to firmly embed HoverKraft practices in your rituals.',
      },
      {
        title: 'Continuous measurement',
        description: 'Before-and-after indicators, quantified ROI, and a monthly feedback loop with your teams.',
      },
    ]}
    image={{
      src: '~/assets/images/pages/offers/questions-answers.png',
      alt: 'Operational management of HoverKraft deliverables',
    }}
  />

  <Features2
    title="Quick comparison"
    subtitle="Pick the option that fits your context."
    columns={2}
    items={[
      {
        title: 'Hoverkraft Audit',
        description: 'Ideal to get a clear picture of your delivery chain and convince leadership.',
        icon: 'tabler:search',
      },
      {
        title: 'Autonomy Package',
        description: 'You have a motivated team and want to grow fast while keeping control.',
        icon: 'tabler:road',
      },
      {
        title: 'Restart',
        description: 'You need to relaunch your platform initiative with coaching, delivery and change management.',
        icon: 'tabler:refresh',
      },
      {
        title: 'PEaaS',
        description: 'You want to externalize part of the platform team while keeping governance.',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <Features3
    title="What’s included"
    subtitle="Each HoverKraft pack combines guidance, deliverables and enablement."
    columns={2}
    items={[
      {
        title: 'Documented deliverables',
        description: 'Written assessments, action plans, dashboards and glue source code in every offer.',
        icon: 'tabler:clipboard-text',
      },
      {
        title: 'Dedicated coaching',
        description: 'A lead Kraft Builder overseeing your mission and facilitating the key rituals.',
        icon: 'tabler:user-star',
      },
      {
        title: 'Open source first',
        description: 'All our connectors are published on GitHub and GitLab to guarantee reversibility.',
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Impact measurement',
        description: 'DORA/SPACE tracking before/after, quantified ROI and 6-month recommendations.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Community support',
        description: 'Access to the OpenKraft community, webinars and exclusive resources.',
        icon: 'tabler:messages',
      },
      {
        title: 'Flexible commitment',
        description: 'Ability to scale up or down depending on your initiatives and pace.',
        icon: 'tabler:arrows-random',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="One consistent framework for every offer"
    items={[
      {
        title: '1. Structured audit',
        description: 'Interviews, metric collection and review of your existing pipelines.',
        icon: 'tabler:clipboard-text',
      },
      {
        title: '2. Shared trajectory',
        description: 'Co-built roadmap aligned with DORA/SPACE metrics and identified quick wins.',
        icon: 'tabler:timeline',
      },
      {
        title: '3. Paired delivery',
        description: 'HoverKraft glue integrated with your teams to ensure adoption.',
        icon: 'tabler:users',
      },
      {
        title: '4. Proof & transfer',
        description: 'Before-and-after dashboards, delivered documentation, and a secure handover.',
        icon: 'tabler:report-analytics',
      },
    ]}
    image={{
      src: '~/assets/images/pages/offers/programming-6.webp',
      alt: 'HoverKraft engineers on mission',
    }}
  />

  <Steps
    title="How to choose your pack"
    tagline="guided process"
    isReversed
    items={[
      {
        title: '1. Complimentary flash audit',
        description: '30 minutes to understand your current challenges and validate the right pack.',
        icon: 'tabler:phone',
      },
      {
        title: '2. Financial projection',
        description: 'ROI estimate based on your current DORA/SPACE metrics.',
        icon: 'tabler:abacus',
      },
      {
        title: '3. Signature & kick-off',
        description: 'Workshop planning and setup of the joint team.',
        icon: 'tabler:calendar-event',
      },
      {
        title: '4. Delivery & measurement',
        description: 'Weekly follow-up, shared dashboards and continuous adaptation.',
        icon: 'tabler:chart-dots',
      },
    ]}
    image={{
      src: '~/assets/images/pages/offers/rbac-and-gouvernance.png',
      alt: 'HoverKraft governance diagram',
    }}
  />

  <FAQs
    title="Frequently asked questions"
    subtitle="Details on our engagement model."
    columns={1}
    items={[
      {
        title: 'Can we start with the audit before committing?',
        description:
          'Yes. The audit is often the entry point. It can be deducted from the chosen pack if the mission starts within 60 days.',
      },
      {
        title: 'Are the listed prices before tax?',
        description:
          'Yes, all amounts are expressed excluding taxes. Any travel expenses are confirmed before signature.',
      },
      {
        title: 'Can we adjust the coaching duration?',
        description: 'The packs are flexible. We adjust duration and scope based on your objectives and teams.',
      },
      {
        title: 'What are the payment terms?',
        description: 'Per-mission invoicing for the audit and autonomy package, monthly for Restart and PEaaS.',
      },
      {
        title: 'Is there a subscription option?',
        description:
          'PEaaS works as a renewable quarterly subscription. We adapt the squad’s capacity to your roadmap.',
      },
    ]}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Choose my offer', href: `${translatePath('/contact')}#booking` },
      { text: 'Explore the method', href: translatePath('/methodology') },
    ]}
  >
    <Fragment slot="title">Need help choosing the right option?</Fragment>
    <Fragment slot="subtitle"
      >Let's review your context and identify the most relevant HoverKraft offer together.</Fragment
    >
  </CallToAction>
</Layout>
