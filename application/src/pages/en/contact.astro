---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import BookingLink from '~/components/widgets/BookingLink.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Sales and support contact',
};

const contactEmail = SITE?.contactEmail ?? '';
const bookingUrl = SITE?.bookingUrl ?? '';
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contact" title="Talk to our team" />

  <BookingLink
    id="booking"
    title="Book a conversation with our team"
    subtitle="Pick a time to discuss your challenges, goals, and constraints."
    bookingUrl={bookingUrl}
    description="We can help with an audit, a platform roadmap, a training plan, or a more specific request."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="How to reach us"
    items={[
      {
        title: 'General support',
        description: `Contact us about account management, billing, service access, or any broader request for information.`,
      },
      {
        title: 'Platform roadmap',
        description:
          'Discuss the right offer, expected trajectory, and the framing needed for your platform initiatives.',
      },
      {
        title: 'Technical question',
        description:
          'Bring us an integration topic, an installation issue, or a specific technical blocker tied to your platform.',
      },
      {
        title: 'Book a slot',
        description: 'Use the shared calendar above to schedule a conversation directly.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Email',
        description: contactEmail,
        icon: 'tabler:mail',
      },
      {
        title: 'Presence',
        description: 'Marseille, Aix-en-Provence, France',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
