---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import { getLangFromUrl, useTranslatedPath } from '~/i18n/utils';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'À propos de HoverKraft',
  description:
    "Découvrez la vision, les valeurs et l'équipe derrière la méthode HoverKraft et son approche fondée sur les connecteurs.",
};

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Notre ADN"
    image={{
      src: '~/assets/images/pages/about/about-us.png',
      alt: 'Développeur libéré grâce à Hoverkraft',
    }}
  >
    <Fragment slot="title">Une équipe de Platform Engineers engagés pour l'autonomie des équipes</Fragment>

    <Fragment slot="subtitle">
      HoverKraft est née d'un constat simple : sans couches d'intégration solides, les meilleurs outils ne suffisent
      pas. Nous concevons une méthode ancrée dans l'open source, pilotée par la mesure et adaptée aux réalités des PME
      et ETI françaises.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Ce que nous mesurons"
    subtitle="Nos engagements se vérifient par les métriques DORA, SPACE et Lean sur chaque mission."
    stats={[
      { title: 'Accélération du time-to-market', amount: '40-60%' },
      { title: 'Réduction des incidents', amount: '60-80%' },
      { title: 'Satisfaction des équipes', amount: '+40-60%' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Pourquoi nous existons"
    subtitle="Une conviction forgée sur le terrain : la plateforme doit être un accélérateur, pas un centre de coût."
    columns={3}
    isBeforeContent
    items={[
      {
        title: 'Vision',
        description:
          "Libérer les développeurs pour qu'ils livrent la valeur métier attendue, sans friction opérationnelle.",
        icon: 'tabler:target',
      },
      {
        title: 'Approche orientée connecteurs',
        description:
          "Nous orchestrons vos outils existants à l'aide de composants open source pour éviter le verrou propriétaire et préserver la réversibilité.",
        icon: 'tabler:puzzle',
      },
      {
        title: 'Mesure continue',
        description:
          'DORA, SPACE et Lean : nos décisions et priorités sont guidées par des métriques partagées avec vos équipes.',
        icon: 'tabler:report-analytics',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent
    items={[
      {
        title: 'Manifeste HoverKraft',
        description: 'Un cadre publié et mis à jour pour aligner toutes les parties prenantes sur la plateforme cible.',
        icon: 'tabler:book',
      },
      {
        title: 'Formations & certification',
        description:
          'Des parcours structurés pour renforcer durablement la maturité de vos équipes en Platform Engineering.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Kraft Builders',
        description:
          'Une équipe de Platform Engineers qui co-construit, transmet et sécurise vos chantiers les plus structurants.',
        icon: 'tabler:users',
      },
      {
        title: 'OpenKraft',
        description: 'Des connecteurs open source maintenus, des tableaux de bord DORA et une communauté active.',
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Transparence totale',
        description: 'Code ouvert, documentation complète, reporting régulier et gouvernance partagée.',
        icon: 'tabler:eye',
      },
      {
        title: 'Souveraineté by design',
        description:
          'Une approche compatible avec les environnements cloud européens et les exigences réglementaires clés.',
        icon: 'tabler:shield-star',
      },
    ]}
    image={{
      src: '~/assets/images/pages/about/hoverkraft-platform-pillars.png',
      alt: 'Les piliers OpenKraft',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Nos valeurs"
    subtitle="Elles guident chaque décision, de la roadmap produit aux interactions avec vos équipes."
    items={[
      {
        title: 'Franchise radicale',
        description:
          "Nous disons ce qui bloque réellement vos équipes, chiffres à l'appui, quitte à bousculer l'ordre établi.",
      },
      {
        title: 'Transfert de compétences',
        description:
          "La mission n'est réussie que lorsque vos équipes peuvent continuer sans nous, outillées et formées.",
      },
      {
        title: 'Impact mesurable',
        description:
          "Pas de slideware : chaque livrable s'accompagne d'indicateurs DORA/SPACE et de feedbacks terrain.",
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Ce qui nous différencie"
    subtitle="Une méthode structurée, une posture d'ingénieurs et une exigence de preuve continue."
    isReversed
    items={[
      {
        title: 'Méthode HoverKraft',
        description:
          "Un cadre opérationnel complet, de l'audit au fonctionnement quotidien, documenté et transmissible.",
        icon: 'tabler:manual-gearbox',
      },
      {
        title: 'Composants open source',
        description: "Nous publions nos connecteurs pour éviter l'effet boîte noire et faciliter la contribution.",
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Kraft Builders',
        description:
          "Une équipe senior, hybride conseil + delivery, capable de piloter et d'exécuter en contexte complexe.",
        icon: 'tabler:users',
      },
    ]}
  />

  <Content
    isReversed
    title="Une équipe hybride"
    subtitle="Des profils qui ont déjà porté les sujets plateforme, produit et transformation dans des contextes exigeants."
    items={[
      {
        title: 'Ingénieurs plateforme',
        description: 'Experts de Kubernetes, GitOps, observabilité, sécurité et automatisation de bout en bout.',
      },
      {
        title: 'Coachs transformation',
        description: 'Spécialistes Lean, DORA et SPACE pour accompagner le changement culturel et organisationnel.',
      },
      {
        title: 'Product & Ops',
        description:
          "Pilotage des chantiers, garantie de l'alignement business et animation de la communauté OpenKraft.",
      },
    ]}
    image={{
      src: '~/assets/images/pages/about/team.png',
      alt: 'Collectif HoverKraft pilotant la plateforme',
    }}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Rencontrer un Kraft Builder', href: translatePath('/contact') },
      { text: 'Découvrir la méthode', href: translatePath('/methodology') },
    ]}
  >
    <Fragment slot="title">Prêts à structurer votre delivery sur des bases solides ?</Fragment>
    <Fragment slot="subtitle"
      >Explorons ensemble comment la méthode HoverKraft peut faire évoluer durablement votre chaîne de delivery.</Fragment
    >
  </CallToAction>
</Layout>
