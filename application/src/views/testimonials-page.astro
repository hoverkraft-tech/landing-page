---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import { getLangFromUrl, useTranslatedPath } from '~/i18n/utils';
import Layout from '~/layouts/PageLayout.astro';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const metadata = {
  title: 'Temoignages HoverKraft',
  description:
    "Retours d'expérience anonymisés sur les transformations delivery et plateforme menées avec la méthode HoverKraft.",
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Temoignages"
    actions={[
      { variant: 'primary', text: 'Parler à un Kraft Builder', href: `${translatePath('/contact')}#booking` },
      { text: 'Découvrir la méthode', href: translatePath('/methodology') },
    ]}
    image={{
      src: '~/assets/images/pages/about/team.png',
      alt: 'Collectif HoverKraft',
    }}
  >
    <Fragment slot="title">Des retours terrain sur des transformations concrètes</Fragment>

    <Fragment slot="subtitle">
      Ces verbatims anonymisés synthétisent ce que les équipes retiennent le plus souvent après une mission HoverKraft :
      une trajectoire plus claire, une meilleure visibilité sur les flux et une charge cognitive mieux maîtrisée.
    </Fragment>
  </Hero>

  <Testimonials
    tagline="Retours anonymisés"
    title="Ce que les équipes retiennent"
    subtitle="Extraits reformulés à partir de missions récentes, sans exposer d'informations sensibles ni de noms clients."
    testimonials={[
      {
        title: 'Clarifier la trajectoire',
        testimonial:
          "Le cadre DORA/SPACE a remis tout le monde autour de la même table. En quelques semaines, nous avions une feuille de route commune et des arbitrages enfin explicites.",
        name: 'Retour anonymisé',
        job: 'Direction engineering - ETI industrielle',
      },
      {
        title: 'Réduire la charge cognitive',
        testimonial:
          "Les templates et les playbooks ont supprimé une partie des bricolages quotidiens. Les équipes ont retrouvé du temps pour livrer au lieu de reconfigurer les mêmes choses.",
        name: 'Retour anonymisé',
        job: 'Lead plateforme - SaaS B2B',
      },
      {
        title: 'Rendre la preuve visible',
        testimonial:
          "Le plus utile a été la visibilité créée par les dashboards et les revues régulières. Nous avons enfin pu discuter investissement, incidents et autonomie sur des faits partagés.",
        name: 'Retour anonymisé',
        job: 'CTO - groupe multi-sites',
      },
    ]}
  />

  <Features2
    title="Pourquoi ces retours comptent"
    subtitle="Ils donnent une image utile de l'impact observé sans transformer le site en vitrine de logos."
    columns={2}
    items={[
      {
        title: 'Impact lisible',
        description: "Les retours mettent l'accent sur la visibilité, les arbitrages et la capacité à faire durer les changements.",
        icon: 'tabler:eye-check',
      },
      {
        title: 'Cadre anonyme',
        description: 'Les missions restent confidentielles, mais les apprentissages utiles peuvent être partagés.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Effets concrets',
        description: 'Les équipes parlent de flux, de rituels, de templates et de transfert plutôt que de slogans abstraits.',
        icon: 'tabler:tool',
      },
      {
        title: 'Point de départ utile',
        description: 'Ces retours servent surtout à qualifier si votre contexte ressemble a ceux deja accompagnes.',
        icon: 'tabler:map-search',
      },
    ]}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Échanger avec nous', href: `${translatePath('/contact')}#booking` },
      { text: 'Voir les offres', href: translatePath('/offers') },
    ]}
  >
    <Fragment slot="title">Vous voulez vérifier si votre contexte ressemble à ces retours ?</Fragment>
    <Fragment slot="subtitle"
      >Partagez vos enjeux actuels et voyons ensemble quel niveau d'accompagnement est le plus pertinent.</Fragment
    >
  </CallToAction>
</Layout>
