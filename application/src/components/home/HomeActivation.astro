---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { HomePageContent } from './types';

export interface Props {
  content: HomePageContent['activation'];
}

const { content } = Astro.props;
const blocks = [content.audit, content.assessment];
---

<WidgetWrapper id="activation" containerClass="py-16 md:py-20 lg:py-24">
  <Headline
    {...content.header}
    classes={{
      container: 'max-w-3xl md:mx-auto text-center',
      title: 'text-3xl md:text-4xl font-bold tracking-tight',
      subtitle: 'text-base md:text-lg leading-relaxed',
    }}
  />

  <div class="grid gap-5 md:grid-cols-2">
    {
      blocks.map((block) => (
        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-white/4 md:p-8">
          <h3 class="text-2xl font-semibold text-heading">{block.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-muted">{block.description}</p>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-default">
            {block.bullets.map((bullet) => (
              <li class="flex gap-3">
                <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-primary" aria-hidden="true" />
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <div class="mt-7">
            <Button {...block.action} class="w-full sm:w-auto" />
          </div>
        </article>
      ))
    }
  </div>
</WidgetWrapper>
