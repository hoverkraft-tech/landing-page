---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { HomePillar, HomeSectionHeader } from './types';

export interface Props {
  header: HomeSectionHeader;
  pillars: HomePillar[];
}

const { header, pillars } = Astro.props;
---

<WidgetWrapper id="platform-model" containerClass="py-16 md:py-20 lg:py-24">
  <Headline
    {...header}
    classes={{
      container: 'max-w-3xl md:mx-auto text-center',
      title: 'text-3xl md:text-4xl font-bold tracking-tight',
      subtitle: 'text-base md:text-lg leading-relaxed',
    }}
  />

  <div class="relative grid gap-5 lg:grid-cols-3">
    <div
      class="absolute left-1/2 top-12 hidden h-px w-2/3 -translate-x-1/2 bg-linear-to-r from-transparent via-primary/30 to-transparent lg:block"
      aria-hidden="true"
    ></div>
    {pillars.map((pillar) => (
        <article class="relative rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-white/4">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name={pillar.icon ?? 'tabler:circle'} class="h-6 w-6" aria-hidden="true" />
          </div>
          <h3 class="text-xl font-semibold text-heading">{pillar.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted">{pillar.description}</p>
          <a
            class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
            href={pillar.action.href}
          >
            {pillar.action.text}
            <Icon name="tabler:arrow-right" class="h-4 w-4" aria-hidden="true" />
          </a>
        </article>
      ))}
  </div>
</WidgetWrapper>
