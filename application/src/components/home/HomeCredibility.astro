---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { HomeCredibilityCard, HomeSectionHeader } from './types';

export interface Props {
  header: HomeSectionHeader;
  cards: HomeCredibilityCard[];
}

const { header, cards } = Astro.props;
---

<WidgetWrapper id="credibility" containerClass="py-16 md:py-20 lg:py-24">
  <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <Headline
      {...header}
      classes={{
        container: 'max-w-2xl text-left md:mx-0',
        title: 'text-3xl md:text-4xl font-bold tracking-tight',
        subtitle: 'text-base md:text-lg leading-relaxed',
      }}
    />

    <div class="grid gap-4 sm:grid-cols-2">
      {cards.map((card) => {
          const Wrapper = card.href ? 'a' : 'article';
          return (
            <Wrapper
              href={card.href}
              class="rounded-2xl border border-gray-200 bg-white p-5 transition-colors hover:border-primary/40 dark:border-white/10 dark:bg-white/4"
            >
              <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <Icon name={card.icon ?? 'tabler:circle'} class="h-5 w-5" aria-hidden="true" />
              </div>
              <h3 class="text-lg font-semibold text-heading">{card.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{card.description}</p>
            </Wrapper>
          );
        })}
    </div>
  </div>
</WidgetWrapper>
