---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/utils';
import type { HomeSectionHeader, HomeUseCase } from './types';

export interface Props {
  header: HomeSectionHeader;
  items: HomeUseCase[];
}

const { header, items } = Astro.props;
const tabIdPrefix = `home-audience-${Math.random().toString(36).slice(2, 8)}`;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<WidgetWrapper id="audiences" containerClass="py-16 md:py-20 lg:py-24">
  <Headline
    {...header}
    classes={{
      container: 'max-w-3xl md:mx-auto text-center',
      title: 'text-3xl md:text-4xl font-bold tracking-tight',
      subtitle: 'text-base md:text-lg leading-relaxed',
    }}
  />

  <div
    class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-white/4"
    data-home-tabs
  >
    <div
      class="grid gap-px border-b border-gray-200 bg-gray-200 sm:grid-cols-2 md:grid-cols-4 dark:border-white/10 dark:bg-white/10"
      role="tablist"
      aria-label={header.title}
    >
      {items.map((item, index) => {
          const isActive = index === 0;
          return (
            <button
              type="button"
              id={`${tabIdPrefix}-tab-${item.id}`}
              class:list={[
                'group relative flex h-full flex-col items-start gap-2 bg-white px-5 py-4 text-left transition-colors focus:outline-hidden focus-visible:ring-3 focus-visible:ring-primary dark:bg-slate-950/40',
                'hover:bg-gray-50 dark:hover:bg-white/5',
                'data-[active=true]:bg-primary/5 dark:data-[active=true]:bg-primary/15',
              ]}
              role="tab"
              aria-selected={isActive ? 'true' : 'false'}
              aria-controls={`${tabIdPrefix}-panel-${item.id}`}
              data-home-tab={item.id}
              data-active={isActive ? 'true' : 'false'}
              tabindex={isActive ? 0 : -1}
            >
              <span
                class:list={[
                  'inline-flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors',
                  'group-data-[active=true]:bg-primary group-data-[active=true]:text-white',
                ]}
              >
                <Icon name={item.icon ?? 'tabler:user'} class="h-5 w-5" aria-hidden="true" />
              </span>
              <span class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-muted">{item.role}</span>
              <span class="text-sm font-semibold leading-snug text-heading md:text-base">{item.title}</span>
              <span
                class="absolute inset-x-5 bottom-0 h-0.5 origin-left scale-x-0 rounded-full bg-primary transition-transform group-data-[active=true]:scale-x-100"
                aria-hidden="true"
              />
            </button>
          );
        })}
    </div>

    <div class="bg-gray-50 p-6 md:p-8 dark:bg-slate-950/50">
      {items.map((item, index) => (
          <article
            id={`${tabIdPrefix}-panel-${item.id}`}
            role="tabpanel"
            aria-labelledby={`${tabIdPrefix}-tab-${item.id}`}
            data-home-panel={item.id}
            hidden={index !== 0}
            tabindex="-1"
            class="focus-visible:outline-hidden"
          >
            <div class="grid gap-6 md:grid-cols-[0.95fr_1.05fr] md:items-stretch">
              <div class="relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/5">
                <div
                  class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-primary/10 blur-2xl"
                  aria-hidden="true"
                />
                <div class="relative">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                      <Icon name={item.icon ?? 'tabler:user'} class="h-5 w-5" aria-hidden="true" />
                    </span>
                    <div>
                      <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-secondary">{item.role}</p>
                      <p class="text-sm font-semibold text-heading">{item.title}</p>
                    </div>
                  </div>
                  <p class="mt-5 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted">
                    {t('home.problem')}
                  </p>
                  <p class="mt-2 text-lg font-semibold leading-snug text-heading md:text-xl">{item.problem}</p>
                </div>
              </div>

              <div class="flex h-full flex-col rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/5">
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-secondary">
                  {t('home.response')}
                </p>
                <p class="mt-2 text-base leading-relaxed text-default md:text-lg">{item.response}</p>

                <p class="mt-6 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted">
                  {t('home.outcomes')}
                </p>
                <ul class="mt-3 grid gap-2">
                  {item.outcomes.map((outcome) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed text-default md:text-base">
                      <Icon
                        name="tabler:circle-check"
                        class="mt-0.5 h-5 w-5 shrink-0 text-primary"
                        aria-hidden="true"
                      />
                      <span>{outcome}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-auto pt-6">
                  <a
                    class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-primary/40"
                    href={item.action.href}
                  >
                    {item.action.text}
                    <Icon name="tabler:arrow-right" class="h-4 w-4" aria-hidden="true" />
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))}
    </div>
  </div>
</WidgetWrapper>

<script>
const initializeHomeTabs = () => {
  document.querySelectorAll<HTMLElement>('[data-home-tabs]').forEach((root) => {
    if (root.dataset.homeTabsInitialized === 'true') return;
    root.dataset.homeTabsInitialized = 'true';

    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[data-home-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-home-panel]'));

    const activate = (activeTab: HTMLElement, focusTab = false) => {
      const activeId = activeTab.getAttribute('data-home-tab');

      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.setAttribute('aria-selected', String(isActive));
        tab.setAttribute('data-active', String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.toggleAttribute('hidden', panel.getAttribute('data-home-panel') !== activeId);
      });

      if (focusTab) {
        activeTab.focus();
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activate(tab));
      tab.addEventListener('keydown', (event: KeyboardEvent) => {
        const key = event.key;
        const keys = ['ArrowLeft', 'ArrowRight', 'Home', 'End', 'Enter', ' '];

        if (!keys.includes(key)) return;
        event.preventDefault();

        if (key === 'Enter' || key === ' ') {
          activate(tab);
          return;
        }

        const nextIndex =
          key === 'Home'
            ? 0
            : key === 'End'
              ? tabs.length - 1
              : key === 'ArrowRight'
                ? (index + 1) % tabs.length
                : (index - 1 + tabs.length) % tabs.length;

        activate(tabs[nextIndex], true);
      });
    });
  });
};

initializeHomeTabs();
document.addEventListener('astro:page-load', initializeHomeTabs);
</script>
