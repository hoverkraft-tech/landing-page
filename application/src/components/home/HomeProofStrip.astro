---
import type { HomeProofPoint } from './types';

export interface Props {
  items: HomeProofPoint[];
}

const { items } = Astro.props;
---

<section class="not-prose border-y border-gray-200 bg-gray-50/80 dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mx-auto grid max-w-7xl gap-0 px-4 py-8 md:grid-cols-4 md:px-6">
    {
      items.map((item) => (
        <div class="border-gray-200 py-5 md:border-r md:px-6 md:first:pl-0 md:last:border-r-0 md:last:pr-0 dark:border-white/10">
          {item.value && <p class="text-3xl font-bold tracking-tight text-heading">{item.value}</p>}
          <p class="text-base font-semibold text-heading">{item.label}</p>
          {item.description && <p class="mt-2 text-sm leading-relaxed text-muted">{item.description}</p>}
        </div>
      ))
    }
  </div>
</section>
