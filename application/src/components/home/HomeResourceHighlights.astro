---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { HomeResource, HomeSectionHeader } from './types';

export interface Props {
  header: HomeSectionHeader;
  items: HomeResource[];
}

const { header, items } = Astro.props;
---

<WidgetWrapper id="resources" containerClass="py-16 md:py-20 lg:py-24">
  <Headline
    {...header}
    classes={{
      container: 'max-w-3xl md:mx-auto text-center',
      title: 'text-3xl md:text-4xl font-bold tracking-tight',
      subtitle: 'text-base md:text-lg leading-relaxed',
    }}
  />

  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
    {
      items.map((item) => (
        <article class="flex min-h-full flex-col rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">{item.type}</p>
          <h3 class="mt-4 text-xl font-semibold leading-snug text-heading">{item.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{item.description}</p>
          <a
            class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.actionText}
            <Icon
              name={item.external ? 'tabler:external-link' : 'tabler:arrow-right'}
              class="h-4 w-4"
              aria-hidden="true"
            />
          </a>
        </article>
      ))
    }
  </div>
</WidgetWrapper>
