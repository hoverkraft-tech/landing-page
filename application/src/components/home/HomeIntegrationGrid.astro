---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { HomePageContent } from './types';

export interface Props {
  content: HomePageContent['integrations'];
}

const { content } = Astro.props;
---

<WidgetWrapper id="integrations" containerClass="py-16 md:py-20 lg:py-24">
  <Headline
    {...content.header}
    classes={{
      container: 'max-w-3xl md:mx-auto text-center',
      title: 'text-3xl md:text-4xl font-bold tracking-tight',
      subtitle: 'text-base md:text-lg leading-relaxed',
    }}
  />

  <div class="flex flex-wrap justify-center gap-3">
    {
      content.items.map((item) => {
        const className =
          'inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-heading dark:border-white/10 dark:bg-white/4';
        return item.href ? (
          <a href={item.href} class={className} target="_blank" rel="noopener noreferrer">
            {item.icon && <Icon name={item.icon} class="h-4 w-4 text-primary" aria-hidden="true" />}
            <span>{item.label}</span>
          </a>
        ) : (
          <span class={className}>
            {item.icon && <Icon name={item.icon} class="h-4 w-4 text-primary" aria-hidden="true" />}
            <span>{item.label}</span>
          </span>
        );
      })
    }
  </div>
</WidgetWrapper>
