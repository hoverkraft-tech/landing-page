---
import { ANALYTICS } from 'astrowind:config';

const googleAnalyticsId = ANALYTICS?.vendors?.googleAnalytics?.id;
const usePartytown = ANALYTICS?.vendors?.googleAnalytics?.partytown ?? true;
const scriptType = usePartytown ? 'text/partytown' : 'text/javascript';
---

{
  googleAnalyticsId ? (
    <Fragment>
      <script
        is:inline
        async
        type={scriptType}
        src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(String(googleAnalyticsId))}`}
      />
      <script
        is:inline
        type={scriptType}
        set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ${JSON.stringify(String(googleAnalyticsId))});
        `}
      />
    </Fragment>
  ) : null
}
