---
import merge from 'lodash.merge';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData, MetaDataImage, MetaDataOpenGraph, MetaDataTwitter } from '~/types';
import { getCanonical } from '~/utils/permalinks';
import { adaptOpenGraphImages } from '~/utils/images';

interface OpenGraphMetadata extends MetaDataOpenGraph {
  site_name?: string;
}

interface Props extends MetaData {
  ignoreTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props as Props;

const pageOpenGraph = openGraph as OpenGraphMetadata;
const configOpenGraph = (METADATA?.openGraph ?? {}) as OpenGraphMetadata;

const mergedOpenGraph = merge(
  {
    url: canonical,
    site_name: SITE?.name,
    images: [],
    locale: I18N?.language || 'en',
    type: 'website',
  },
  configOpenGraph,
  { url: canonical, ...pageOpenGraph }
) as OpenGraphMetadata;

const normalizedOpenGraph = await adaptOpenGraphImages(
  {
    ...mergedOpenGraph,
    siteName: pageOpenGraph.siteName ?? configOpenGraph.siteName,
  },
  Astro.site
);

const robotsIndex = robots?.index ?? METADATA?.robots?.index ?? false;
const robotsFollow = robots?.follow ?? METADATA?.robots?.follow ?? false;
const robotsContent = `${robotsIndex ? 'index' : 'noindex'}, ${robotsFollow ? 'follow' : 'nofollow'}`;

const defaultTitle = METADATA?.title?.default ?? '';
const titleTemplate = ignoreTitleTemplate ? '%s' : (METADATA?.title?.template ?? '%s');
const resolvedTitle = title ?? defaultTitle;
const documentTitle = title
  ? titleTemplate.includes('%s')
    ? titleTemplate.replace('%s', title)
    : `${titleTemplate}${title}`
  : resolvedTitle;

const resolvedDescription = description ?? METADATA?.description;
const resolvedTwitter = merge(
  {
    cardType: normalizedOpenGraph?.images?.length ? 'summary_large_image' : 'summary',
  },
  METADATA?.twitter ?? {},
  twitter
) as MetaDataTwitter;

const openGraphSiteName =
  normalizedOpenGraph.siteName ?? mergedOpenGraph.siteName ?? mergedOpenGraph.site_name ?? SITE?.name;

const openGraphImages = (normalizedOpenGraph.images ?? []).filter((image): image is MetaDataImage =>
  Boolean(image?.url)
);
const twitterImage = openGraphImages[0];
---

<title>{documentTitle}</title>
<link rel="canonical" href={canonical} />
<meta name="robots" content={robotsContent} />
{resolvedDescription ? <meta name="description" content={resolvedDescription} /> : null}

<meta property="og:title" content={resolvedTitle} />
<meta property="og:type" content={normalizedOpenGraph.type ?? 'website'} />
<meta property="og:url" content={normalizedOpenGraph.url ?? canonical} />
{resolvedDescription ? <meta property="og:description" content={resolvedDescription} /> : null}
{openGraphSiteName ? <meta property="og:site_name" content={openGraphSiteName} /> : null}
{normalizedOpenGraph.locale ? <meta property="og:locale" content={normalizedOpenGraph.locale} /> : null}

{
  openGraphImages.map((image) => (
    <Fragment>
      <meta property="og:image" content={image.url} />
      {image.width ? <meta property="og:image:width" content={String(image.width)} /> : null}
      {image.height ? <meta property="og:image:height" content={String(image.height)} /> : null}
    </Fragment>
  ))
}

<meta name="twitter:card" content={resolvedTwitter.cardType ?? 'summary'} />
<meta name="twitter:title" content={resolvedTitle} />
{resolvedDescription ? <meta name="twitter:description" content={resolvedDescription} /> : null}
{resolvedTwitter.site ? <meta name="twitter:site" content={resolvedTwitter.site} /> : null}
{resolvedTwitter.handle ? <meta name="twitter:creator" content={resolvedTwitter.handle} /> : null}
{twitterImage ? <meta name="twitter:image" content={twitterImage.url} /> : null}
