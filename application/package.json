{
  "name": "@hoverkraft-tech/landing-page",
  "version": "1.0.0",
  "description": "Hoverkraft marketing site built with Astro and Tailwind CSS.",
  "private": true,
  "homepage": "https://hoverkraft.cloud",
  "bugs": {
    "url": "https://github.com/hoverkraft-tech/landing-page/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoverkraft-tech/landing-page.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev --host",
    "prebuild": "node ./scripts/generate-downloadable-assets/index.mjs prepare",
    "build": "astro check && astro build",
    "postbuild": "node ./scripts/generate-downloadable-assets/index.mjs finalize",
    "preview": "astro preview",
    "astro": "ASTRO_TELEMETRY_DISABLED=1 astro",
    "humanize:check": "node ./scripts/humanize-content.mjs --check",
    "humanize:fix": "node ./scripts/humanize-content.mjs --write",
    "format": "biome format --write .",
    "lint": "npm run lint:biome && npm run lint:astro && npm run humanize:check",
    "lint:astro": "astro check",
    "lint:biome": "biome lint --error-on-warnings .",
    "lint:fix": "npm run humanize:fix && npm run lint:fix:biome",
    "lint:ci": "sh -c 'biome lint --error-on-warnings . --reporter=sarif > biome-report.txt 2>&1 && cat biome-report.txt && npm run lint:astro > astro-report.txt 2>&1 && cat astro-report.txt && node ./scripts/humanize-content.mjs --check --report-file humanize-report-checkstyle.xml'",
    "lint:fix:biome": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:ci": "npm run test -- --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "@iconify-json/tabler": "^1.2.35",
    "archiver": "^8.0.0",
    "astro": "^6.4.6",
    "astro-embed": "^0.13.0",
    "astro-icon": "^1.1.5",
    "limax": "4.2.3",
    "lodash.merge": "^4.6.2",
    "marked": "^18.0.3",
    "puppeteer": "^25.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/partytown": "^2.1.7",
    "@biomejs/biome": "^2.3.11",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/archiver": "^7.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@vitest/coverage-v8": "4.1.7",
    "astro-compress": "2.4.1",
    "humanize-ai-lib": "^1.0.0",
    "js-yaml": "^4.1.1",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "4.1.7"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
